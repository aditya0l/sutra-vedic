rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'contact@sutravedic.fr';
    }

    match /{allPaths=**} {
      // Public read access to all images (products, categories, etc.)
      allow read: if true;
      
      // Only admins can upload or delete files
      // Limits uploads to < 5MB and requires image content type
      allow write: if isAdmin() 
                   && request.resource.size < 5 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
                   
      allow delete: if isAdmin();
    }
  }
}
